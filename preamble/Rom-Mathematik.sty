\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{./preamble/Rom-Mathematik}

%% -- Mathematische Pakete
%% --
\let\digamma\relax
\RequirePackage{amsmath,amssymb}
\RequirePackage[tbtags]{mathtools}
\RequirePackage{mleftright}

%% -- Theorem-Umgebungen
%% --
\RequirePackage{./preamble/Rom-Theorem}

%% -- Zahlbereiche
%% --

\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\C}{\mathbb{C}}
\newcommand{\K}{\mathbb{K}}

%% -- Differentiale
%% --

\newcommand*{\diff}[1]{\mathop{}\!\mathrm{d}{#1}}
\newcommand*{\ds}{\mathop{}\!\mathrm{d}{s}}
\newcommand*{\dg}{\mathop{}\!\mathrm{d}{g}}
\newcommand*{\dt}{\mathop{}\!\mathrm{d}{t}}
\newcommand*{\dx}{\mathop{}\!\mathrm{d}{x}}
\newcommand*{\dy}{\mathop{}\!\mathrm{d}{y}}
\newcommand*{\dr}{\mathop{}\!\mathrm{d}{r}}

%% -- Eulersche Zahl und imaginäre Einheit
%% --

\newcommand{\eu}{\ensuremath{\mathrm{e}}}
\newcommand{\iu}{\ensuremath{\mathrm{i}}}

%% -- Griechische Buchstaben und Operatoren
%% --
\AtBeginDocument{%
    \let\ORGvarepsilon\varepsilon
    \let\varepsilon\epsilon
    \let\epsilon\ORGvarepsilon
    \let\ORGvarrho\varrho
    \let\varrho\rho
    \let\rho\ORGvarrho
    \let\ORGvartheta\vartheta
    \let\vartheta\theta
    \let\theta\ORGvartheta
    \let\ORGvarphi\varphi
    \let\varphi\phi
    \let\phi\ORGvarphi
    %% -- Vergleichsoperatoren
    \let\ORGvarleq\leqslant
    \let\leqslant\leq
    \let\leq\ORGvarleq
    \let\ORGvargeq\geqslant
    \let\geqslant\geq
    \let\geq\ORGvargeq
    \let\ORGvarpreccurlyeq\preccurlyeq
    \let\preccurlyeq\preceq
    \let\preceq\ORGvarpreccurlyeq
    %% -- Mengenoperationen
    \let\setminus\smallsetminus
    \renewcommand{\P}{\mathfrak{P}}
    %% -- Operator L(E,F)
    \let\ORGL\L
    \DeclareRobustCommand{\L}[1]{\mathcal{L}(#1)}
}

%% -- Norm und Absolutbetrag
%% --

\DeclarePairedDelimiterX{\norm}[1]{\lVert}{\rVert}
    {\ifblank{#1}{\:\cdot\:}{#1}}
\DeclarePairedDelimiterX{\abs}[1]{\lvert}{\rvert}
    {\ifblank{#1}{\:\cdot\:}{#1}}

%% --

\endinput
