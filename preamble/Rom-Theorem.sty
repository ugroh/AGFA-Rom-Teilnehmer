%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Rom-Theorem.sty -- Theorem-Umgebungen
%% -- Stand: 2026-03-07
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{./preamble/Rom-Theorem}

\RequirePackage{amsmath}
\RequirePackage{amsthm}
\RequirePackage{thmtools}

%% Gleichungsnummerierung
%% --

\numberwithin{equation}{section}

%% -- Stile
%% --

\declaretheoremstyle[
  headfont=\bfseries, bodyfont=\itshape, headindent=5pt,
]{plain-style}
\declaretheoremstyle[
  headfont=\bfseries, bodyfont=\upshape, headindent=5pt,
]{upshape-style}
\declaretheoremstyle[
  headfont=\bfseries, bodyfont={\small\upshape}, headindent=5pt,
]{small-style}
\declaretheoremstyle[
  headfont=\itshape, bodyfont=\upshape, headindent=5pt,
]{special-style}

%% -- Theoremumgebungen MIT Nummer
%% --

\declaretheorem[style=plain-style,   
    name=Theorem,    
    numberwithin=section]{ntheorem}

\declaretheorem[style=plain-style,   
    name=Satz,       
    sibling=ntheorem]{nproposition}

\declaretheorem[style=plain-style,   
    name=Lemma,      
    sibling=ntheorem]{nlemma}

\declaretheorem[style=plain-style,
    name=Korollar,   
    sibling=ntheorem]{ncorollary}

\declaretheorem[style=upshape-style, 
    name=Beispiel,   
    sibling=ntheorem]{nexample}

\declaretheorem[style=upshape-style, 
    name=Beispiele,  
    sibling=ntheorem]{nexamples}

\declaretheorem[style=upshape-style, 
    name=Definition, 
    sibling=ntheorem]{ndefinition}
    
\declaretheorem[style=small-style,   
    name=Anmerkung,  
    sibling=ntheorem]{nremark}
    
\declaretheorem[style=small-style, 
    name=Anmerkungen,
    sibling=ntheorem]{nremarks}

%% -- Theoremumgebungen OHNE Nummer
%% --

\declaretheorem[style=plain-style,   
    name=Theorem,    
    numbered=no]{theorem}

\declaretheorem[style=plain-style,   
    name=Satz,       
    numbered=no]{proposition}

\declaretheorem[style=plain-style,   
    name=Lemma,      
    numbered=no]{lemma}

\declaretheorem[style=plain-style,   
    name=Korollar,   
    numbered=no]{corollary}

\declaretheorem[style=upshape-style, 
    name=Beispiel,   
    numbered=no]{example}

\declaretheorem[style=upshape-style, 
    name=Beispiele,  
    numbered=no]{examples}

\declaretheorem[style=upshape-style, 
    name=Definition, 
    numbered=no]{definition}

\declaretheorem[style=small-style,   
    name=Anmerkung,  
    numbered=no]{remark}

\declaretheorem[style=small-style,   
    name=Anmerkungen,
    numbered=no]{remarks}

%% -- Spezielle Umgebungen
%% --
\declaretheorem[style=special-style, 
    name=Zusammenfassung, 
    numbered=no]{summary}
    
\declaretheorem[style=special-style, 
    name=Frage,           
    numbered=no]{question}

%% -- Beweis mit Halmosstein
%% --

\renewcommand\qedsymbol{\ensuremath{\square}}
\addto\captionsgerman{\renewcommand{\proofname}{Beweis}}

%% --
\endinput