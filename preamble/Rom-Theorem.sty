%% Rom-Theorem.sty -- Theorem-Umgebungen
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{./preamble/Rom-Theorem}

\RequirePackage{amsmath}
\RequirePackage[amsmath,thmmarks]{ntheorem}

%% Gleichungsnummerierung
%% HINWEIS: numberwithin setzt Zähler pro Sektion UND Format (1.1, 1.2,...)
%% renewcommand überschreibt nur das Format → Zähler reset bleibt, aber
%% Anzeige ist 1, 2, ... (unüblich). Eines von beiden entfernen!
\numberwithin{equation}{section}
%\renewcommand\theequation{\arabic{equation}}

%% Theoremumgebungen MIT Nummer
\theoremstyle{plain}
\newtheorem{ntheorem}{Theorem}
\newtheorem{nproposition}[ntheorem]{Satz}
\newtheorem{nlemma}[ntheorem]{Lemma}
\newtheorem{ncorollary}[ntheorem]{Korollar}

\theorembodyfont{\upshape}
\theoremindent5pt
\newtheorem{nexample}[ntheorem]{Beispiel}
\newtheorem{nexamples}[ntheorem]{Beispiele}
\newtheorem{ndefinition}[ntheorem]{Definition}

\theorembodyfont{\small}
\newtheorem{nremark}[ntheorem]{Anmerkung}
\newtheorem{nremarks}[ntheorem]{Anmerkungen}

%% Theoremumgebungen OHNE Nummer
\theoremstyle{nonumberplain}
\theorembodyfont{\normalfont}
\theoremindent5pt
\newtheorem{theorem}{Theorem}
\newtheorem{proposition}{Satz}
\newtheorem{lemma}{Lemma}
\newtheorem{corollary}{Korollar}

\theorembodyfont{\upshape}
\newtheorem{example}{Beispiel}
\newtheorem{examples}{Beispiele}
\newtheorem{definition}{Definition}

\theorembodyfont{\small}
\newtheorem{remark}{Anmerkung}
\newtheorem{remarks}{Anmerkungen}

%% Spezielle Umgebungen
\theoremheaderfont{\itshape}
\theoremseparator{}
\theorembodyfont{\upshape}
\newtheorem{summary}{Zusammenfassung}
\newtheorem{question}{Frage}

%% Beweis mit Halmosstein
\theoremsymbol{\ensuremath{\square}}
\newtheorem{proof}{Beweis}

\endinput
















