\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{./preamble/Rom-Beitrag}
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\RequirePackage{ifthen}
\provideboolean{review}

%% -- KOMA-Optionen
\DeclareOption*{\expandafter\PassOptionsToClass\expandafter{\CurrentOption}{scrartcl}}

\KOMAoptions{%
    ,paper    = a4
    ,pagesize
    ,BCOR     = 10mm
    ,twoside  = true
    ,fontsize  = 12pt
    ,headings  = small
    ,open      = any
}

%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Für Headings, TOC etc
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\DeclareRobustCommand{\LongTitel}{}
\DeclareRobustCommand{\ShortTitel}{}
\DeclareRobustCommand{\AutorenBeitrag}{}
\DeclareRobustCommand{\ShortTitelTOC}{}
\DeclareRobustCommand{\ShortTitelKopfzeile}{}
\DeclareOption{review}{\setboolean{review}{true}}
\ProcessOptions\relax

%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Pakete
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{scrhack}
\RequirePackage{./preamble/Rom-Layout}
\RequirePackage{./preamble/Rom-BibLaTeX}
\RequirePackage{./preamble/Rom-Pakete}


%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Schrift (pdfLaTeX)
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[T1]{fontenc}
\RequirePackage{libertinus}

%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Sprache
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[english,italian,french,main=ngerman]{babel}
%\babelprovide[hyphenrules=ngerman-x-latest]{ngerman}

%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Anführungszeichen
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[%
    ,autostyle
    ,italian = guillemets
    ,french  = guillemets
    ,german  = guillemets
    ,english = american]{csquotes}

%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% -- Querverweise
%% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[nospace]{varioref}
\RequirePackage[breaklinks=true]{hyperref}
\RequirePackage{bookmark}
\hypersetup{%
    ,colorlinks = true
    ,urlcolor   = blue
    ,citecolor  = blue
    ,linkcolor  = blue
    ,hypertexnames=true
}

%% -- Eigene Pakete
\RequirePackage{./preamble/Rom-Abkuerzungen}
\RequirePackage{./preamble/Rom-Mathematik}

%% -- cleveref nach amsmath laden
\RequirePackage{cleveref}

%% -- Review-Modus
\ifthenelse{\boolean{review}}{\RequirePackage[doublespacing]{setspace}}{}

